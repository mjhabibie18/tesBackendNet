{
  // appsettings.Development.json — Konfigurasi Development
  // ========================================================
  // File ini OVERRIDE appsettings.json saat environment = Development.
  // File ini AMAN untuk commit ke git (tidak ada credential production).
  //
  // Cara menggunakan:
  //   1. Pastikan ASPNETCORE_ENVIRONMENT=Development (default saat dotnet run)
  //   2. Ganti connection string sesuai SQL Server lokal Anda
  //   3. Jalankan: dotnet ef database update
  //   4. Jalankan: dotnet run
  //
  // Connection String Format:
  //   SQL Server Local (Windows Auth):
  //     "Server=.;Database=DbName;Trusted_Connection=True;TrustServerCertificate=True;"
  //   SQL Server Local (SQL Auth):
  //     "Server=.;Database=DbName;User Id=sa;Password=YourPass;TrustServerCertificate=True;"
  //   SQL Server LocalDB:
  //     "Server=(localdb)\\mssqllocaldb;Database=DbName;Trusted_Connection=True;"
  //   Docker SQL Server:
  //     "Server=localhost,1434;Database=DbName;User Id=sa;Password=TesBackendNet@2024!;TrustServerCertificate=True;"
  // ========================================================

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      // Tampilkan SQL query yang dieksekusi EF Core (berguna untuk debug)
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "ConnectionStrings": {
    // ── PILIH SALAH SATU SESUAI SETUP ANDA ──────────────────

    // Opsi 1: SQL Server Local dengan Windows Authentication (Paling umum)
    // "DefaultConnection": "Server=.;Database=TesBackendNet_CRUD;Trusted_Connection=True;TrustServerCertificate=True;"

    // Opsi 2: SQL Server LocalDB (jika install via Visual Studio)
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=TesBackendNet_CRUD;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;"

    // Opsi 3: SQL Server dengan SQL Authentication
    // "DefaultConnection": "Server=.;Database=TesBackendNet_CRUD;User Id=sa;Password=YourPassword;TrustServerCertificate=True;"

    // Opsi 4: Docker SQL Server (jalankan docker-compose up -d dulu)
    // "DefaultConnection": "Server=localhost,1434;Database=TesBackendNet_CRUD;User Id=sa;Password=TesBackendNet@2024!;TrustServerCertificate=True;"
  }
}